" ===============================================================
" CONFIGURAÇÃO VIM RETRÔ PWB FORTRAN - VERSÃO FINAL AJUSTADA
" ===============================================================

set nocompatible
set encoding=utf-8
syntax on

" --- 1. INTERFACE E NÚMEROS (O QUE VOCÊ PEDIU) ---
set number
set relativenumber
set laststatus=2
set showcmd

" --- 2. CORES CLÁSSICAS (AZUL PWB SEM MARROM) ---
set termguicolors

" Fundo Azul e Texto Branco
highlight Normal       guibg=#0000AA guifg=#FFFFFF ctermbg=Blue ctermfg=White
" Coluna de Números (Garante que o Relativenumber apareça no azul)
highlight LineNr       guibg=#0000AA guifg=#888888 ctermbg=Blue ctermfg=Grey
highlight CursorLineNr guibg=#0000AA guifg=#FFFF00 ctermbg=Blue ctermfg=Yellow gui=bold

" Colunas Guia 7 e 72 (Saímos do marrom para um Vermelho Vinho discreto)
set colorcolumn=7,72
highlight ColorColumn  guibg=#550000 ctermbg=DarkRed

" Pontinhos (....) em Azul Escuro para não cansar a vista
set list
set listchars=space:·,tab:»\ 
highlight SpecialKey   guifg=#0044FF ctermfg=DarkBlue

" --- 3. REGRAS RÍGIDAS FORTRAN E TAB ---
set virtualedit=all
set expandtab
set tabstop=6
set shiftwidth=6
set softtabstop=6

" O seu Tab 'Voador': pula direto para a coluna 7 no modo inserção
inoremap <Tab> <C-O>:call cursor(line('.'), 7)<CR>

" --- 4. COMPORTAMENTO DO MODO VISUAL ---
" Se você estiver revisando e quiser editar, aperte 'i' e ele não apaga o texto
vnoremap i <Esc>i
vnoremap a <Esc>a

" --- FINALIZAÇÃO ---
set background=dark
filetype indent off

" --- MÁGICA DO F5: SALVAR E RODAR (FORTRAN OU BASH) ---
" Se o arquivo termina em .sh, roda com o bash.
" Se termina em .for ou .f90, compila com gfortran e roda.
function! ExecutarCodigo()
    exec "w"
    if &filetype == 'sh' || expand('%:e') == 'sh'
        exec "!bash %"
    elseif &filetype == 'fortran' || expand('%:e') =~ 'for\|f90'
        exec "!gfortran % -o %< && ./%<"
    else
        echo "LumiLoka: Formato não reconhecido para F5!"
    endif
endfunction

nnoremap <F5> :call ExecutarCodigo()<CR>
inoremap <F5> <Esc>:call ExecutarCodigo()<CR>

function! ExecutarCodigo()
    exec "w"
    " Roda direto no buffer azul, sem limpar a tela
    if &filetype == 'sh' || expand('%:e') == 'sh'
        exec "!bash %"
    elseif &filetype == 'fortran' || expand('%:e') =~ 'for\|f90'
        exec "!gfortran % -o %< && ./%<"
    else
        echo "LumiLoka: Formato não reconhecido!"
    endif
endfunction

nnoremap <F5> :call ExecutarCodigo()<CR>
inoremap <F5> <Esc>:call ExecutarCodigo()<CR>

