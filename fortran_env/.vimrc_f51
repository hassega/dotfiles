" --- CONFIGURAÇÃO VIM RETRÔ (PWB FORTRAN 5.1 STYLE) ---
set nocompatible
set number              " Mostra números de linha (ajuda no Fortran)set relativenumbers

set syntax=fortran      " Ativa realce de sintaxe para .FOR
set encoding=utf-8

" --- CORES CLÁSSICAS DO DOS (Fundo Azul, Texto Branco/Cinza) ---
highlight Normal ctermfg=White ctermbg=Blue
highlight Constant ctermfg=Yellow ctermbg=Blue
highlight Comment ctermfg=Cyan ctermbg=Blue
highlight Statement ctermfg=White ctermbg=Blue cterm=bold
highlight LineNr ctermfg=Grey ctermbg=Blue
highlight CursorLineNr ctermfg=Yellow ctermbg=Blue cterm=bold

" --- COMPORTAMENTO FORTRAN 77 (Colunas e Tabs) ---
set expandtab
set shiftwidth=4
set softtabstop=4
set tabstop=4
set autoindent

" --- FORÇAR AZUL SÓLIDO (MATAR TRANSPARÊNCIA NO KONSOLE) ---
set termguicolors
" Comandos para o Vim 'conversar' melhor com o terminal moderno
let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"

" Pintando o fundo com Azul Sólido (#0000AA é o azul original do DOS)
highlight Normal guibg=#0000AA guifg=#FFFFFF
highlight NonText guibg=#0000AA
highlight LineNr guibg=#0000AA guifg=#AAAAAA
highlight CursorLineNr guibg=#0000AA guifg=#FFFF00 cterm=bold

" Garante que o fundo não fique transparente ao sair do texto
set background=dark
